# Required — used by scorer, cover letter generator, form analyzer
OPENAI_API_KEY=sk-...

# Required — Adzuna job collector
ADZUNA_APP_ID=...
ADZUNA_APP_KEY=...

# Optional — only needed for actually sending emails (otherwise prints to stdout)
RESEND_API_KEY=re_...
AMANE_EMAIL=amane@example.com

